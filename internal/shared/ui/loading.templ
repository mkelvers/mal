package ui

templ LoadingIndicator(text string) {
	<div class="inline-flex items-center gap-2 text-sm text-[var(--text-muted)]">
		<div class="h-1.5 w-1.5 rounded-full bg-[var(--text-faint)]"></div>
		<div class="h-1.5 w-1.5 rounded-full bg-[var(--text-faint)]"></div>
		<div class="h-1.5 w-1.5 rounded-full bg-[var(--text-faint)]"></div>
		<span>{ text }</span>
	</div>
}
